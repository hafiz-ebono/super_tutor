# AI provider — switch provider/model here only, no code changes needed
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-4o
AGENT_API_KEY=sk-...

# URL extraction (optional — if empty, skip Jina layer and go straight to trafilatura)
JINA_API_KEY=jina_...

# Tavily — web search for research agent (https://app.tavily.com)
TAVILY_API_KEY=tvly-...

# CORS — comma-separated allowed origins or JSON-formatted list
ALLOWED_ORIGINS=http://localhost:3000
# Example for multiple:
# ALLOWED_ORIGINS=http://localhost:3000,http://another.com
# ALLOWED_ORIGINS=["http://localhost:3000","http://another.com"]

# Agno Control Plane — remote telemetry at app.agno.com (optional, Phase 7)
# Create account at https://app.agno.com to get your API key
# AGNO_TELEMETRY=true enables SDK telemetry (default); set to false to disable
AGNO_API_KEY=
AGNO_TELEMETRY=true
