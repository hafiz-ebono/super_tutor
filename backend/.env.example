# AI provider — switch provider/model here only, no code changes needed
AGENT_PROVIDER=openai
AGENT_MODEL=gpt-4o
AGENT_API_KEY=sk-...

# URL extraction (optional — if empty, skip Jina layer and go straight to trafilatura)
JINA_API_KEY=jina_...

# CORS — comma-separated allowed origins or JSON-formatted list
ALLOWED_ORIGINS=http://localhost:3000
# Example for multiple:
# ALLOWED_ORIGINS=http://localhost:3000,http://another.com
# ALLOWED_ORIGINS=["http://localhost:3000","http://another.com"]
